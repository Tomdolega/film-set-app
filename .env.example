# Core app
DATABASE_URL=postgres://postgres:postgres@localhost:5432/film_set_app
PORT=3001
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=false

# Session cookie
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=

# Uploads
DOCUMENT_UPLOAD_MAX_BYTES=20971520

# Storage
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_REGION=auto
STORAGE_BUCKET=film-set-app
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900

# Dev seed
DEV_SEED_USER_ID=11111111-1111-1111-1111-111111111111
DEV_SEED_USER_EMAIL=owner@example.com
DEV_SEED_USER_NAME=Demo Owner
DEV_SEED_USER_PASSWORD=dev-password
DEV_SEED_ORGANIZATION_ID=22222222-2222-2222-2222-222222222222
DEV_SEED_ORGANIZATION_NAME=Demo Organization
