        "domains/integrations-calendar/src/index.ts"
      ],
      "@film-set-app/domain-notifications": [
        "domains/notifications/src/index.ts"
      ],
      "@film-set-app/domain-organizations": [
        "domains/organizations/src/index.ts"
      ],
      "@film-set-app/domain-projects": [
        "domains/projects/src/index.ts"
